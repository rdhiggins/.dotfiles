# Core tools
brew "git"
brew "gh"
brew "curl"
brew "wget"
brew "zsh"
brew "openssl@3"

# Modern CLI replacements
brew "bat"            # cat replacement with syntax highlighting
brew "eza"            # ls replacement (successor to exa)
brew "fd"             # find replacement
brew "fzf"            # fuzzy finder
brew "git-delta"      # better git diffs
brew "ripgrep"        # grep replacement
brew "starship"       # cross-shell prompt
brew "zoxide"         # cd/autojump replacement

# Development tools
brew "cmake"
brew "gcc"
brew "htop"
brew "httpie"
brew "jq"
brew "midnight-commander"
brew "mint"
brew "ninja"
brew "nmap"
brew "tree"
brew "swiftformat"
brew "swiftlint"
brew "ruby-build"
brew "python-build"

# Language version manager (replaces rbenv, pyenv, nvm)
brew "mise"

cask "macdown"
